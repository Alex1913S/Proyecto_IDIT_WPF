<Window x:Class="Presentación.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Presentación"
        mc:Ignorable="d"
        Title="Login" Height="650" Width="920"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent">

    <Border x:Name="MainWindowBorder" Background="#060621" CornerRadius="18" MouseLeftButtonDown="Window_MouseLeftButtonDown">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3.5*"/>
                <ColumnDefinition Width="6.5*"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="BtnThemeToggle"
                    HorizontalAlignment="Left" 
                    VerticalAlignment="Top" 
                    Margin="15,15,0,0" 
                    Grid.Column="0"
                    Width="32" Height="32"
                    Background="Transparent" 
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="ThemeToggle_Click"
                    Panel.ZIndex="10">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ThemeBtnBorder" Background="Transparent" CornerRadius="16">
                            <Path x:Name="ThemeIcon" 
                                  Data="M12,2A10,10 0 1,1 2,12A10,10 0 0,1 12,2M12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4Z" 
                                  Fill="#A0A0B8" Width="18" Height="18" Stretch="Uniform" 
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThemeBtnBorder" Property="Background" Value="#151538"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button Content="✕" 
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Top" 
                    Margin="0,15,15,0" 
                    Grid.Column="1"
                    Width="25" Height="25"
                    Foreground="White" 
                    FontSize="14" 
                    Cursor="Hand"
                    Click="CloseButton_Click"
                    Panel.ZIndex="10">
                <Button.Resources>
                    <Style TargetType="Button">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="BtnBorder" 
                                            Background="#888888" 
                                            BorderBrush="#888888" 
                                            BorderThickness="1.5" 
                                            CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="BtnBorder" Property="Background" Value="#E89A24"/>
                                            <Setter TargetName="BtnBorder" Property="BorderBrush" Value="White"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="BtnBorder" Property="Background" Value="#E89A24"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Resources>
            </Button>

            <StackPanel Grid.Column="0" Margin="35,0,25,0" VerticalAlignment="Center">

                <TextBlock x:Name="LblTitle"
                           Text="Bienvenido a&#x0a;IDIT" 
                           Foreground="White" 
                           FontSize="32" 
                           FontWeight="Bold" 
                           Margin="0,0,0,35" 
                           LineHeight="38"/>

                <TextBlock x:Name="LblUser" Text="Usuario" Foreground="White" FontSize="16" Margin="0,0,0,8"/>
                <TextBox Height="38" Background="White" FontSize="14" Margin="0,0,0,20">
                    <TextBox.Resources>
                        <Style TargetType="TextBox">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TextBox">
                                        <Border x:Name="TextBorder" Background="{TemplateBinding Background}" BorderBrush="#CCCCCC" BorderThickness="1.5" CornerRadius="8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="35"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Path x:Name="UserIcon" Data="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z" Fill="#888888" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Column="0"/>
                                                <ScrollViewer x:Name="PART_ContentHost" Grid.Column="1" VerticalAlignment="Center" Margin="5,0,10,0"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsFocused" Value="True">
                                                <Setter TargetName="TextBorder" Property="BorderBrush" Value="#E89A24"/>
                                                <Setter TargetName="TextBorder" Property="BorderThickness" Value="2"/>
                                                <Setter TargetName="UserIcon" Property="Fill" Value="#E89A24"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <TextBlock x:Name="LblPassword" Text="Contraseña" Foreground="White" FontSize="16" Margin="0,0,0,8"/>
                <Grid Margin="0,0,0,15">
                    <PasswordBox x:Name="TxtPassword" Height="38" Background="White" FontSize="14">
                        <PasswordBox.Resources>
                            <Style TargetType="PasswordBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="PasswordBox">
                                            <Border x:Name="PasswordBorder" Background="{TemplateBinding Background}" BorderBrush="#CCCCCC" BorderThickness="1.5" CornerRadius="8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="35"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="40"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Path x:Name="LockIcon" Data="M12,17A2,2 0 0,0 14,15C14,13.89 13.11,13 12,13A2,2 0 0,0 10,15A2,2 0 0,0 12,17M18,8A2,2 0 0,1 20,10V20A2,2 0 0,1 18,22H6A2,2 0 0,1 4,20V10C4,8.89 4.89,8 6,8H7V6A5,5 0 0,1 12,1A5,5 0 0,1 17,6V8H18M12,3A3,3 0 0,0 9,6V8H15V6A3,3 0 0,0 12,3Z" Fill="#888888" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Column="0"/>
                                                    <ScrollViewer x:Name="PART_ContentHost" Grid.Column="1" VerticalAlignment="Center" Margin="5,0,5,0"/>
                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsFocused" Value="True">
                                                    <Setter TargetName="PasswordBorder" Property="BorderBrush" Value="#E89A24"/>
                                                    <Setter TargetName="PasswordBorder" Property="BorderThickness" Value="2"/>
                                                    <Setter TargetName="LockIcon" Property="Fill" Value="#E89A24"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </PasswordBox.Resources>
                    </PasswordBox>

                    <TextBox x:Name="TxtPasswordRevealed" Height="38" Background="White" FontSize="14" Visibility="Collapsed">
                        <TextBox.Resources>
                            <Style TargetType="TextBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TextBox">
                                            <Border x:Name="TextBorder" Background="{TemplateBinding Background}" BorderBrush="#CCCCCC" BorderThickness="1.5" CornerRadius="8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="35"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="40"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Path x:Name="LockIconOpen" Data="M12,17A2,2 0 0,0 14,15C14,13.89 13.11,13 12,13A2,2 0 0,0 10,15A2,2 0 0,0 12,17M18,8A2,2 0 0,1 20,10V20A2,2 0 0,1 18,22H6A2,2 0 0,1 4,20V10C4,8.89 4.89,8 6,8H7V6A5,5 0 0,1 12,1A5,5 0 0,1 17,6V8H18M12,3A3,3 0 0,0 9,6V8H15V6A3,3 0 0,0 12,3Z" Fill="#E89A24" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Column="0"/>
                                                    <ScrollViewer x:Name="PART_ContentHost" Grid.Column="1" VerticalAlignment="Center" Margin="5,0,5,0"/>
                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsFocused" Value="True">
                                                    <Setter TargetName="TextBorder" Property="BorderBrush" Value="#E89A24"/>
                                                    <Setter TargetName="TextBorder" Property="BorderThickness" Value="2"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>

                    <Button x:Name="BtnTogglePassword" Width="30" Height="30" Background="Transparent" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Right" Margin="0,0,5,0" Click="BtnTogglePassword_Click">
                        <Path x:Name="EyeIcon" Data="M12,4.5C7,4.5 2.73,7.61 1,12C2.73,16.39 7,19.5 12,19.5C17,19.5 21.27,16.39 23,12C21.27,7.61 17,4.5 12,4.5M12,17A5,5 0 0,1 7,12A5,5 0 0,1 12,7A5,5 0 0,1 17,12A5,5 0 0,1 12,17M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9Z" Fill="#A0A0B8" Stretch="Uniform" Width="20"/>
                    </Button>
                </Grid>

                <TextBlock x:Name="LblTerms" Text="Acepta los terminos y condiciones." Foreground="White" FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,8"/>

                <CheckBox x:Name="ChkTerms" HorizontalAlignment="Center" Margin="0,0,0,35" Cursor="Hand">
                    <CheckBox.Template>
                        <ControlTemplate TargetType="CheckBox">
                            <Border x:Name="CustomBorder" 
                                    Width="18" Height="18" 
                                    Background="Transparent" 
                                    BorderBrush="#888888" 
                                    BorderThickness="1.2" 
                                    CornerRadius="4">
                                <Path x:Name="CheckMark" 
                                      Data="M9,20.42L2.79,14.21L5.62,11.38L9,14.77L18.88,4.88L21.71,7.71L9,20.42Z" 
                                      Fill="#E89A24" 
                                      Stretch="Uniform" 
                                      Width="11" Height="11" 
                                      Opacity="0"
                                      HorizontalAlignment="Center" 
                                      VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="CustomBorder" Property="BorderBrush" Value="#E89A24"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="CheckMark" Property="Opacity" Value="1"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </CheckBox.Template>
                </CheckBox>

                <Button Content="Iniciar Sesión" Foreground="#060621" FontSize="16" FontWeight="SemiBold" Height="45" BorderThickness="0" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="ButtonBorder" Background="#E89A24" CornerRadius="10">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FFB33B"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="ButtonBorder" Property="Background" Value="#C47E1B"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Resources>
                </Button>

            </StackPanel>

            <Grid Grid.Column="1" Margin="10,44,10,10">
                <Border x:Name="RightImageBorder" CornerRadius="30" ClipToBounds="True" Background="#060621" Margin="-13,0,10,0">
                    <Image Source="pack://application:,,,/Assets/image_login_1.png" 
                           Stretch="UniformToFill"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center" Height="596" Width="720" Margin="-139,0,0,0"/>
                </Border>
            </Grid>

        </Grid>
    </Border>
</Window>