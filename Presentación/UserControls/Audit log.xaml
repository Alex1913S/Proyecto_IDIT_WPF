<UserControl x:Class="Presentación.Audit_Log"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1000"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             Background="Transparent"
             Loaded="UserControl_Loaded">

    <UserControl.Resources>

        <!-- ══ SCROLLBAR CUSTOM ══ -->
        <Style x:Key="ScrollBarLineButton" TargetType="RepeatButton">
            <Setter Property="Visibility" Value="Collapsed"/>
        </Style>
        <Style x:Key="ScrollBarPageButton" TargetType="RepeatButton">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ScrollBarThumb" TargetType="Thumb">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="Border" CornerRadius="4" Background="#1a4a7a" Margin="2"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#2F80ED"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#2F80ED"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="8"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Background="Transparent">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <RepeatButton Grid.Row="0" Style="{StaticResource ScrollBarLineButton}" Command="ScrollBar.LineUpCommand"/>
                                    <Track x:Name="PART_Track" Grid.Row="1" IsDirectionReversed="True">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource ScrollBarPageButton}" Command="ScrollBar.PageUpCommand"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource ScrollBarThumb}"/>
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource ScrollBarPageButton}" Command="ScrollBar.PageDownCommand"/>
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                    <RepeatButton Grid.Row="2" Style="{StaticResource ScrollBarLineButton}" Command="ScrollBar.LineDownCommand"/>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="8"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Background="Transparent">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <RepeatButton Grid.Column="0" Style="{StaticResource ScrollBarLineButton}" Command="ScrollBar.LineLeftCommand"/>
                                    <Track x:Name="PART_Track" Grid.Column="1" IsDirectionReversed="False">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource ScrollBarPageButton}" Command="ScrollBar.PageLeftCommand"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource ScrollBarThumb}"/>
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource ScrollBarPageButton}" Command="ScrollBar.PageRightCommand"/>
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                    <RepeatButton Grid.Column="2" Style="{StaticResource ScrollBarLineButton}" Command="ScrollBar.LineRightCommand"/>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ══ PAGER BUTTON ══ -->
        <Style x:Key="PagerButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A0A0B8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#0d3a5c"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#1a4a7a"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ DATAGRID ══ -->
        <Style x:Key="ModernDataGridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeight" Value="50"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A0C4E0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,12"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#0e3560"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="CenterCellStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#0d3a5c"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0D0D2D"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1a4a7a"/>
                    <Setter Property="Foreground" Value="#2F80ED"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ══ ACTION BUTTON ══ -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ INPUT MODERNO ══ -->
        <Style x:Key="ModernInputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="#0d3a5c"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#1a4a7a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,3"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#2F80ED"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="B" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="B" Property="BorderBrush" Value="#2F80ED"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="B" Property="BorderBrush" Value="#2F80ED"/>
                                <Setter TargetName="B" Property="BorderThickness" Value="1.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ LABEL CAMPO ══ -->
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="#5a8ab0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

    </UserControl.Resources>

    <Grid x:Name="RootGrid" Background="Transparent">
        <Grid Margin="15,10,15,10">
            <Grid.ColumnDefinitions>
                <!-- Panel lateral detalle -->
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="15"/>
                <!-- Área principal -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ══════════════════════════════════════════════════
                 COLUMNA 0 — Panel lateral (filtros + detalle)
            ══════════════════════════════════════════════════ -->
            <Border x:Name="PanelLateralBorder" Grid.Column="0" Background="#09274c" CornerRadius="12"
                    BorderBrush="#0d3a5c" BorderThickness="1" Padding="15">
                <StackPanel>

                    <!-- Encabezado panel -->
                    <Border Width="60" Height="60" CornerRadius="30"
                            Background="#071d34" HorizontalAlignment="Center"
                            BorderBrush="#2F80ED" BorderThickness="2" Margin="0,0,0,12">
                        <Path Data="M12,2C6.5,2 2,6.5 2,12C2,17.5 6.5,22 12,22C17.5,22 22,17.5 22,12C22,6.5 17.5,2 12,2M12,4C16.4,4 20,7.6 20,12C20,16.4 16.4,20 12,20C7.6,20 4,16.4 4,12C4,7.6 7.6,4 12,4M11,6V13H16V11.5H12.5V6H11Z"
                              Fill="#2F80ED" Width="28" Height="28" Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="Filtros de Auditoría" FontSize="14" FontWeight="Bold"
                               Foreground="White" TextAlignment="Center"
                               HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock Text="Consulta por rango de fechas" FontSize="11" Foreground="#A0C4E0"
                               TextAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,16"/>

                    <Separator Background="#0e3560" Margin="0,0,0,14"/>

                    <!-- Filtro Desde -->
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="FECHA DESDE" Style="{StaticResource FieldLabelStyle}"/>
                        <DatePicker x:Name="DpDesde" Height="36"/>
                    </StackPanel>

                    <!-- Filtro Hasta -->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="FECHA HASTA" Style="{StaticResource FieldLabelStyle}"/>
                        <DatePicker x:Name="DpHasta" Height="36"/>
                    </StackPanel>

                    <!-- Botón Consultar -->
                    <Button x:Name="BtnConsultar"
                            Content="🔍  Consultar Logs"
                            Style="{StaticResource ActionButtonStyle}"
                            Background="#2F80ED" Foreground="#08213a"
                            Margin="0,0,0,8"
                            Click="BtnConsultar_Click"/>

                    <Button x:Name="BtnLimpiar"
                            Content="↺  Limpiar Filtros"
                            Style="{StaticResource ActionButtonStyle}"
                            Background="#0d3a5c" Foreground="#A0C4E0"
                            Margin="0,0,0,16"
                            Click="BtnLimpiar_Click"/>

                    <Separator Background="#0e3560" Margin="0,0,0,14"/>

                    <!-- Detalle del log seleccionado -->
                    <TextBlock Text="DETALLE DEL REGISTRO" Style="{StaticResource FieldLabelStyle}"
                               Margin="0,0,0,10"/>

                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Tabla Afectada" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBlock x:Name="TxtPanelTabla" Text="—" FontSize="13" Foreground="White"
                                   TextWrapping="Wrap" Margin="0,2,0,0"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Acción" Style="{StaticResource FieldLabelStyle}"/>
                        <Border Background="#0d3a5c" CornerRadius="6" Padding="8,4"
                                HorizontalAlignment="Left" Margin="0,4,0,0">
                            <TextBlock x:Name="TxtPanelAccion" Text="—"
                                       FontSize="12" FontWeight="SemiBold" Foreground="#A0C4E0"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Usuario BD" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBlock x:Name="TxtPanelUsuario" Text="—" FontSize="13" Foreground="White"
                                   TextWrapping="Wrap" Margin="0,2,0,0"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Fecha y Hora" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBlock x:Name="TxtPanelFecha" Text="—" FontSize="13" Foreground="White"
                                   Margin="0,2,0,0"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,0">
                        <TextBlock Text="ID Registro" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBlock x:Name="TxtPanelRegistroId" Text="—" FontSize="12"
                                   Foreground="#5a8ab0" Margin="0,2,0,0"/>
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- ══════════════════════════════════════════════════
                 COLUMNA 2 — Área principal
            ══════════════════════════════════════════════════ -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="55"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Margin="0,0,0,15">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="TxtTitulo" Text="Log de Auditoría SGSI"
                                   FontSize="18" FontWeight="Bold" Foreground="White"/>
                        <TextBlock x:Name="TxtSubtitulo" Text="Trazabilidad completa de operaciones en base de datos"
                                   FontSize="12" Foreground="#A0C4E0" Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <!-- Contador de registros encontrados -->
                        <Border x:Name="BadgeContador" Background="#0d3a5c" CornerRadius="8"
                                Padding="12,6" Margin="0,0,12,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Registros: " FontSize="12" Foreground="#5a8ab0" FontWeight="SemiBold"/>
                                <TextBlock x:Name="TxtTotalRegistros" Text="0" FontSize="12"
                                           Foreground="#2F80ED" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                        <Button x:Name="BtnExportarExcel"
                                Content="Exportar Excel"
                                Width="130" Height="36"
                                Background="#107C41" Foreground="White"
                                FontWeight="SemiBold" BorderThickness="0"
                                Cursor="Hand" Click="BtnExportarExcel_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Panel expansible: Datos Anteriores / Nuevos -->
                <Border x:Name="PanelDiffBorder" Grid.Row="1"
                        Background="#0d3a5c" CornerRadius="8"
                        BorderBrush="#1a4a7a" BorderThickness="1"
                        Padding="12,10" Margin="0,0,0,12"
                        Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="VALOR ANTERIOR" FontSize="10" Foreground="#e7133f"
                                       FontWeight="Bold" Margin="0,0,0,6"/>
                            <ScrollViewer Height="80" VerticalScrollBarVisibility="Auto">
                                <TextBlock x:Name="TxtDetalleAnterior" Text="—" FontSize="11"
                                           Foreground="#A0C4E0" TextWrapping="Wrap"/>
                            </ScrollViewer>
                        </StackPanel>

                        <Rectangle Grid.Column="1" Width="1" Fill="#1a4a7a" VerticalAlignment="Stretch" Margin="0,4"/>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="VALOR NUEVO" FontSize="10" Foreground="#4CD964"
                                       FontWeight="Bold" Margin="0,0,0,6"/>
                            <ScrollViewer Height="80" VerticalScrollBarVisibility="Auto">
                                <TextBlock x:Name="TxtDetalleNuevo" Text="—" FontSize="11"
                                           Foreground="#A0C4E0" TextWrapping="Wrap"/>
                            </ScrollViewer>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- DataGrid -->
                <Border x:Name="GridBorder" Grid.Row="2" Background="#09274c" CornerRadius="8"
                        BorderBrush="#0d3a5c" BorderThickness="1" Padding="10">
                    <Grid>
                        <!-- Estado vacío -->
                        <StackPanel x:Name="PanelVacio" VerticalAlignment="Center"
                                    HorizontalAlignment="Center" Visibility="Visible">
                            <TextBlock Text="🔍" FontSize="48" HorizontalAlignment="Center"
                                       Margin="0,0,0,12"/>
                            <TextBlock Text="Sin resultados aún" FontSize="16" FontWeight="Bold"
                                       Foreground="#A0C4E0" TextAlignment="Center"/>
                            <TextBlock Text="Selecciona un rango de fechas y presiona Consultar Logs"
                                       FontSize="12" Foreground="#5a8ab0"
                                       TextAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>

                        <DataGrid x:Name="DgLogs"
                                  Style="{StaticResource ModernDataGridStyle}"
                                  SelectionChanged="DgLogs_SelectionChanged"
                                  Visibility="Collapsed">
                            <DataGrid.Columns>

                                <DataGridTextColumn Header="Log ID" Binding="{Binding LogID}" Width="0.7*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#5a8ab0"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="Tabla Afectada" Binding="{Binding TablaAfectada}" Width="1.3*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#2F80ED"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="Acción" Binding="{Binding Accion}" Width="0.9*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Style.Triggers>
                                                <Trigger Property="Text" Value="INSERT">
                                                    <Setter Property="Foreground" Value="#4CD964"/>
                                                </Trigger>
                                                <Trigger Property="Text" Value="UPDATE">
                                                    <Setter Property="Foreground" Value="#FF9500"/>
                                                </Trigger>
                                                <Trigger Property="Text" Value="DELETE">
                                                    <Setter Property="Foreground" Value="#e7133f"/>
                                                </Trigger>
                                                <Trigger Property="Text" Value="SELECT">
                                                    <Setter Property="Foreground" Value="#34AADC"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="Usuario BD" Binding="{Binding UsuarioBD}"
                                                   Width="1.2*" ElementStyle="{StaticResource CenterCellStyle}"/>

                                <DataGridTextColumn Header="Fecha y Hora"
                                                   Binding="{Binding FechaAccion, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}"
                                                   Width="1.3*" ElementStyle="{StaticResource CenterCellStyle}"/>

                                <DataGridTextColumn Header="ID Registro" Binding="{Binding RegistroID}"
                                                   Width="1.1*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#A0C4E0"/>
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTemplateColumn Header="Diff" Width="0.6*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="#071d34" CornerRadius="4" Padding="6,3"
                                                    HorizontalAlignment="Center" Cursor="Hand">
                                                <TextBlock Text="Ver" FontSize="11" FontWeight="Bold"
                                                           Foreground="#2F80ED"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <!-- Info barra -->
                <Grid Grid.Row="3" Margin="0,8,0,0">
                    <TextBlock x:Name="TxtInfoPagina" Text="Página 1 de 1"
                               Foreground="#A0C4E0" FontSize="12"
                               HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button x:Name="BtnPaginaAnterior" Style="{StaticResource PagerButtonStyle}"
                                Click="BtnPaginaAnterior_Click">
                            <TextBlock Text="‹" FontSize="18" FontWeight="Bold" Margin="0,0,0,2"/>
                        </Button>
                        <StackPanel x:Name="PnlNumerosPagina" Orientation="Horizontal"/>
                        <Button x:Name="BtnPaginaSiguiente" Style="{StaticResource PagerButtonStyle}"
                                Click="BtnPaginaSiguiente_Click">
                            <TextBlock Text="›" FontSize="18" FontWeight="Bold" Margin="0,0,0,2"/>
                        </Button>
                    </StackPanel>
                    <TextBlock x:Name="TxtContadorRegistros" Text="Mostrando 0 registros"
                               Foreground="#A0C4E0" FontSize="12"
                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>

                <!-- Spacer -->
                <Border Grid.Row="4"/>

            </Grid>
        </Grid>
    </Grid>
</UserControl>
