<UserControl x:Class="Presentación.Employee_Viewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1000"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             Background="Transparent"
             Loaded="UserControl_Loaded">

    <UserControl.Resources>

        <!-- ══════════════════ SCROLLBAR CUSTOM (igual a See_Assets) ══════════════════ -->
        <Style x:Key="ScrollBarLineButton" TargetType="RepeatButton">
            <Setter Property="Visibility" Value="Collapsed"/>
        </Style>
        <Style x:Key="ScrollBarPageButton" TargetType="RepeatButton">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ScrollBarThumb" TargetType="Thumb">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="Border" CornerRadius="4" Background="#3F3F6B" Margin="2"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#E89A24"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#C27E1B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="10"/>
                    <Setter Property="Height" Value="Auto"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Background="#050518">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <RepeatButton Grid.Row="0" Style="{StaticResource ScrollBarLineButton}" Command="ScrollBar.LineUpCommand"/>
                                    <Track x:Name="PART_Track" Grid.Row="1" IsDirectionReversed="True">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource ScrollBarPageButton}" Command="ScrollBar.PageUpCommand"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource ScrollBarThumb}"/>
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource ScrollBarPageButton}" Command="ScrollBar.PageDownCommand"/>
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                    <RepeatButton Grid.Row="2" Style="{StaticResource ScrollBarLineButton}" Command="ScrollBar.LineDownCommand"/>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ══════════════════ TAB FILTER (igual a See_Assets) ══════════════════ -->
        <Style x:Key="TabFilterButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A0A0B8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Margin" Value="0,0,15,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="TabBorder" Background="{TemplateBinding Background}"
                                BorderBrush="Transparent" BorderThickness="0,0,0,2"
                                Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal">
                                <ContentPresenter VerticalAlignment="Center"/>
                                <Border x:Name="Badge" Margin="8,0,0,0" Background="#151538"
                                        CornerRadius="10" Padding="6,2" VerticalAlignment="Center">
                                    <TextBlock x:Name="BadgeText"
                                               Text="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"
                                               FontSize="11" Foreground="#A0A0B8" FontWeight="Bold"/>
                                </Border>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#3F3F6B"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#E89A24"/>
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#E89A24"/>
                                <Setter TargetName="BadgeText" Property="Foreground" Value="#E89A24"/>
                                <Setter TargetName="Badge" Property="Background" Value="#1b1b4a"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══════════════════ PAGER BUTTON ══════════════════ -->
        <Style x:Key="PagerButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A0A0B8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#151538"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#3F3F6B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══════════════════ DATAGRID ══════════════════ -->
        <Style x:Key="ModernDataGridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeight" Value="52"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A0A0B8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,12"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#1F1F45"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="CenterGridCellStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#151538"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0D0D2D"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1F1F45"/>
                    <Setter Property="Foreground" Value="#E89A24"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ══════════════════ ACTION BUTTON ══════════════════ -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <!-- ══════════════════════════════════════════════════════════════
         LAYOUT PRINCIPAL — dos columnas: panel lateral foto + tabla
    ══════════════════════════════════════════════════════════════ -->
    <Grid Background="Transparent">
        <Grid Margin="15,10,15,10">
            <Grid.ColumnDefinitions>
                <!-- Panel lateral con foto y datos del colaborador seleccionado -->
                <ColumnDefinition Width="220"/>
                <!-- Separación -->
                <ColumnDefinition Width="15"/>
                <!-- Área principal: buscador + tabs + grid + paginador -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ══════════════════════════════════════════════════════
                 COLUMNA 0 — Panel lateral del colaborador seleccionado
            ══════════════════════════════════════════════════════ -->
            <Border Grid.Column="0" Background="#090924" CornerRadius="12"
                    BorderBrush="#151538" BorderThickness="1" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Foto circular -->
                        <RowDefinition Height="Auto"/>
                        <!-- Nombre -->
                        <RowDefinition Height="Auto"/>
                        <!-- Cargo -->
                        <RowDefinition Height="Auto"/>
                        <!-- Badge rol -->
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="Auto"/>
                        <!-- Datos detalle -->
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <!-- Botones acción -->
                    </Grid.RowDefinitions>

                    <!-- Foto circular -->
                    <Border Grid.Row="0" Width="110" Height="110"
                            CornerRadius="55" HorizontalAlignment="Center"
                            BorderBrush="#E89A24" BorderThickness="2"
                            Margin="0,0,0,12" Background="#151538"
                            ClipToBounds="True">
                        <Grid>
                            <!-- Avatar placeholder cuando no hay foto -->
                            <TextBlock x:Name="TxtAvatarInicial"
                                       Text="?" FontSize="40" FontWeight="Bold"
                                       Foreground="#3F3F6B"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            <!-- Imagen cargada desde BD -->
                            <Image x:Name="ImgFotoColaborador"
                                   Stretch="UniformToFill"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Visibility="Collapsed"/>
                        </Grid>
                    </Border>

                    <!-- Nombre completo -->
                    <TextBlock x:Name="TxtPanelNombre"
                               Grid.Row="1"
                               Text="Selecciona un colaborador"
                               FontSize="14" FontWeight="Bold"
                               Foreground="White"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,4"/>

                    <!-- Cargo -->
                    <TextBlock x:Name="TxtPanelCargo"
                               Grid.Row="2"
                               Text="—"
                               FontSize="12"
                               Foreground="#A0A0B8"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>

                    <!-- Badge de Perfil/Rol -->
                    <Border x:Name="BadgePerfil"
                            Grid.Row="3"
                            HorizontalAlignment="Center"
                            Background="#1b1b4a"
                            CornerRadius="10" Padding="10,4"
                            Margin="0,0,0,0">
                        <TextBlock x:Name="TxtPanelPerfil"
                                   Text="—"
                                   FontSize="11" FontWeight="Bold"
                                   Foreground="#E89A24"/>
                    </Border>

                    <!-- Separador -->
                    <Separator Grid.Row="4" Background="#1F1F45" Margin="0,10"/>

                    <!-- Datos detalle -->
                    <StackPanel Grid.Row="5" Margin="0,0,0,0">
                        <!-- Cédula -->
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Identificación" FontSize="10" Foreground="#3F3F6B" FontWeight="SemiBold"/>
                            <TextBlock x:Name="TxtPanelCedula" Text="—" FontSize="13" Foreground="White" Margin="0,2,0,0"/>
                        </StackPanel>
                        <!-- Correo -->
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Correo Corporativo" FontSize="10" Foreground="#3F3F6B" FontWeight="SemiBold"/>
                            <TextBlock x:Name="TxtPanelCorreo" Text="—" FontSize="12" Foreground="#A0A0B8"
                                       TextWrapping="Wrap" Margin="0,2,0,0"/>
                        </StackPanel>
                        <!-- Departamento -->
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Departamento" FontSize="10" Foreground="#3F3F6B" FontWeight="SemiBold"/>
                            <TextBlock x:Name="TxtPanelDepartamento" Text="—" FontSize="13" Foreground="White" Margin="0,2,0,0"/>
                        </StackPanel>
                        <!-- Estado -->
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Estado" FontSize="10" Foreground="#3F3F6B" FontWeight="SemiBold"/>
                            <Border x:Name="BadgeEstado" Background="#151538" CornerRadius="6"
                                    Padding="8,3" HorizontalAlignment="Left" Margin="0,4,0,0">
                                <TextBlock x:Name="TxtPanelEstado" Text="—" FontSize="12" FontWeight="SemiBold" Foreground="#A0A0B8"/>
                            </Border>
                        </StackPanel>
                        <!-- Fecha de ingreso -->
                        <StackPanel Margin="0,0,0,0">
                            <TextBlock Text="Fecha de Ingreso" FontSize="10" Foreground="#3F3F6B" FontWeight="SemiBold"/>
                            <TextBlock x:Name="TxtPanelFechaIngreso" Text="—" FontSize="13" Foreground="White" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Botones de acción -->
                    <StackPanel Grid.Row="7" Margin="0,12,0,0">
                        <Button x:Name="BtnEditar"
                                Content="Editar Colaborador"
                                Style="{StaticResource ActionButtonStyle}"
                                Background="#151538" Foreground="#E89A24"
                                Margin="0,0,0,8"
                                IsEnabled="False"
                                Click="BtnEditar_Click"/>
                        <Button x:Name="BtnEliminar"
                                Content="Eliminar"
                                Style="{StaticResource ActionButtonStyle}"
                                Background="#2D1A22" Foreground="#E53E3E"
                                IsEnabled="False"
                                Click="BtnEliminar_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════════════════════
                 COLUMNA 2 — Área principal (buscador + tabs + grid + paginador)
            ══════════════════════════════════════════════════════ -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Header: título + buscador -->
                    <RowDefinition Height="Auto"/>
                    <!-- Tabs de filtro -->
                    <RowDefinition Height="*"/>
                    <!-- DataGrid -->
                    <RowDefinition Height="55"/>
                    <!-- Paginador -->
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock Text="Gestión de Colaboradores"
                               FontSize="18" FontWeight="Bold"
                               Foreground="White"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Border Width="260" Height="36" Background="#151538"
                                BorderBrush="#3F3F6B" BorderThickness="1"
                                CornerRadius="6" Margin="0,0,12,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="35"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="🔍" Foreground="#A0A0B8"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           FontSize="12"/>
                                <TextBox x:Name="TxtBuscarColaborador"
                                         Grid.Column="1"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="White"
                                         VerticalContentAlignment="Center"
                                         FontSize="13"
                                         CaretBrush="#E89A24"
                                         TextChanged="TxtBuscarColaborador_TextChanged"/>
                            </Grid>
                        </Border>
                        <Button x:Name="BtnExportarExcel"
                                Content="Exportar Excel"
                                Width="120" Height="36"
                                Background="#107C41" Foreground="White"
                                FontWeight="SemiBold" BorderThickness="0"
                                Cursor="Hand"
                                Click="BtnExportarExcel_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Tabs de filtro por rol -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,5,0,15">
                    <Button x:Name="BtnTabTodos"
                            Content="Todos"
                            Style="{StaticResource TabFilterButtonStyle}"
                            IsEnabled="False" Tag="0"
                            Click="FilterTab_Click"/>
                    <Button x:Name="BtnTabAdministradores"
                            Content="Administradores"
                            Style="{StaticResource TabFilterButtonStyle}"
                            Tag="0"
                            Click="FilterTab_Click"/>
                    <Button x:Name="BtnTabOperadores"
                            Content="Operadores"
                            Style="{StaticResource TabFilterButtonStyle}"
                            Tag="0"
                            Click="FilterTab_Click"/>
                    <Button x:Name="BtnTabEmpleados"
                            Content="Empleados"
                            Style="{StaticResource TabFilterButtonStyle}"
                            Tag="0"
                            Click="FilterTab_Click"/>
                </StackPanel>

                <!-- DataGrid de colaboradores -->
                <Border Grid.Row="2" Background="#090924" CornerRadius="8"
                        BorderBrush="#151538" BorderThickness="1" Padding="10">
                    <DataGrid x:Name="DgColaboradores"
                              Style="{StaticResource ModernDataGridStyle}"
                              SelectionChanged="DgColaboradores_SelectionChanged">
                        <DataGrid.Columns>

                            <!-- Identificación -->
                            <DataGridTextColumn Header="Identificación"
                                               Binding="{Binding DocumentoIdentidad}"
                                               Width="1.3*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#E89A24"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Nombre completo -->
                            <DataGridTextColumn Header="Colaborador"
                                               Binding="{Binding NombreCompleto}"
                                               Width="1.6*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontWeight" Value="Medium"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Cargo -->
                            <DataGridTextColumn Header="Cargo"
                                               Binding="{Binding Cargo}"
                                               Width="1.2*"
                                               ElementStyle="{StaticResource CenterGridCellStyle}"/>

                            <!-- Departamento -->
                            <DataGridTextColumn Header="Departamento"
                                               Binding="{Binding NombreDepartamento}"
                                               Width="1.2*"
                                               ElementStyle="{StaticResource CenterGridCellStyle}"/>

                            <!-- Perfil / Rol — con color por tipo -->
                            <DataGridTextColumn Header="Perfil"
                                               Binding="{Binding NombrePerfil}"
                                               Width="1.1*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="FontWeight" Value="Medium"/>
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="Administrador">
                                                <Setter Property="Foreground" Value="#E89A24"/>
                                            </Trigger>
                                            <Trigger Property="Text" Value="Operador">
                                                <Setter Property="Foreground" Value="#34AADC"/>
                                            </Trigger>
                                            <Trigger Property="Text" Value="Empleado">
                                                <Setter Property="Foreground" Value="#4CD964"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Correo -->
                            <DataGridTextColumn Header="Correo"
                                               Binding="{Binding CorreoCorporativo}"
                                               Width="1.6*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#A0A0B8"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Estado — Activo / Inactivo -->
                            <DataGridTextColumn Header="Estado"
                                               Binding="{Binding EstadoTexto}"
                                               Width="0.9*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="Activo">
                                                <Setter Property="Foreground" Value="#4CD964"/>
                                            </Trigger>
                                            <Trigger Property="Text" Value="Inactivo">
                                                <Setter Property="Foreground" Value="#E53E3E"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Fecha de ingreso -->
                            <DataGridTextColumn Header="Ingreso"
                                               Binding="{Binding FechaIngreso, StringFormat='{}{0:dd/MM/yyyy}'}"
                                               Width="1*"
                                               ElementStyle="{StaticResource CenterGridCellStyle}"/>

                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <!-- Paginador -->
                <Grid Grid.Row="3" Margin="0,10,0,0">
                    <TextBlock x:Name="TxtInfoPagina"
                               Text="Página 1 de 1"
                               Foreground="#A0A0B8" FontSize="13"
                               HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button x:Name="BtnPaginaAnterior"
                                Style="{StaticResource PagerButtonStyle}"
                                Click="BtnPaginaAnterior_Click">
                            <TextBlock Text="‹" FontSize="18" FontWeight="Bold" Margin="0,0,0,2"/>
                        </Button>
                        <StackPanel x:Name="PnlNumerosPagina" Orientation="Horizontal"/>
                        <Button x:Name="BtnPaginaSiguiente"
                                Style="{StaticResource PagerButtonStyle}"
                                Click="BtnPaginaSiguiente_Click">
                            <TextBlock Text="›" FontSize="18" FontWeight="Bold" Margin="0,0,0,2"/>
                        </Button>
                    </StackPanel>
                    <TextBlock x:Name="TxtContadorRegistros"
                               Text="Mostrando 0 registros"
                               Foreground="#A0A0B8" FontSize="12"
                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>

            </Grid>
        </Grid>
    </Grid>
</UserControl>
