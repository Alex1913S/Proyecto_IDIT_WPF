<UserControl x:Class="Presentación.GestorContrasenas"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1000"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             Background="Transparent"
             Loaded="UserControl_Loaded">

    <UserControl.Resources>

        <!-- ══ SCROLLBAR CUSTOM ══ -->
        <Style x:Key="ScrollBarLineButton" TargetType="RepeatButton">
            <Setter Property="Visibility" Value="Collapsed"/>
        </Style>
        <Style x:Key="ScrollBarPageButton" TargetType="RepeatButton">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ScrollBarThumb" TargetType="Thumb">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="Border" CornerRadius="4" Background="#3F3F6B" Margin="2"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#E89A24"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="10"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Background="#050518">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <RepeatButton Grid.Row="0" Style="{StaticResource ScrollBarLineButton}" Command="ScrollBar.LineUpCommand"/>
                                    <Track x:Name="PART_Track" Grid.Row="1" IsDirectionReversed="True">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource ScrollBarPageButton}" Command="ScrollBar.PageUpCommand"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource ScrollBarThumb}"/>
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource ScrollBarPageButton}" Command="ScrollBar.PageDownCommand"/>
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                    <RepeatButton Grid.Row="2" Style="{StaticResource ScrollBarLineButton}" Command="ScrollBar.LineDownCommand"/>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ══ TAB FILTER ══ -->
        <Style x:Key="TabFilterButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A0A0B8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Margin" Value="0,0,15,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="TabBorder" Background="{TemplateBinding Background}"
                                BorderBrush="Transparent" BorderThickness="0,0,0,2"
                                Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal">
                                <ContentPresenter VerticalAlignment="Center"/>
                                <Border x:Name="Badge" Margin="8,0,0,0" Background="#151538"
                                        CornerRadius="10" Padding="6,2" VerticalAlignment="Center">
                                    <TextBlock x:Name="BadgeText"
                                               Text="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"
                                               FontSize="11" Foreground="#A0A0B8" FontWeight="Bold"/>
                                </Border>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#3F3F6B"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#E89A24"/>
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#E89A24"/>
                                <Setter TargetName="BadgeText" Property="Foreground" Value="#E89A24"/>
                                <Setter TargetName="Badge" Property="Background" Value="#1b1b4a"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ PAGER BUTTON ══ -->
        <Style x:Key="PagerButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A0A0B8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#151538"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#3F3F6B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ DATAGRID ══ -->
        <Style x:Key="ModernDataGridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeight" Value="50"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A0A0B8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,12"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#1F1F45"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="CenterCellStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#151538"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0D0D2D"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1F1F45"/>
                    <Setter Property="Foreground" Value="#E89A24"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ══ INPUT MODERNO ══ -->
        <Style x:Key="ModernInputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="#151538"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3F3F6B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,3"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#E89A24"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="B" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="B" Property="BorderBrush" Value="#E89A24"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="B" Property="BorderBrush" Value="#E89A24"/>
                                <Setter TargetName="B" Property="BorderThickness" Value="1.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ COMBO MODERNO ══ -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#E89A24"/>
                                <Setter Property="Foreground" Value="#060621"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#3F3F6B"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <ControlTemplate x:Key="ComboToggleBtn" TargetType="ToggleButton">
            <Border x:Name="Brd" Background="#151538" BorderBrush="#3F3F6B"
                    BorderThickness="1" CornerRadius="6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="30"/>
                    </Grid.ColumnDefinitions>
                    <Path x:Name="Arrow" Grid.Column="1" Fill="#A0A0B8"
                          HorizontalAlignment="Center" VerticalAlignment="Center"
                          Data="M 0 0 L 4 4 L 8 0 Z"/>
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Brd" Property="BorderBrush" Value="#E89A24"/>
                    <Setter TargetName="Arrow" Property="Fill" Value="#E89A24"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="Brd" Property="BorderBrush" Value="#E89A24"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
        <Style x:Key="ModernComboStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#151538"/>
            <Setter Property="BorderBrush" Value="#3F3F6B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0,0,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Template="{StaticResource ComboToggleBtn}"
                                          Focusable="false"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            <Popup x:Name="Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid x:Name="DropDown" SnapsToDevicePixels="True"
                                      MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border Background="#090924" BorderBrush="#3F3F6B"
                                            BorderThickness="1" CornerRadius="6" Margin="0,3,0,0">
                                        <ScrollViewer Margin="0,2" SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True"
                                                        KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ ACTION BUTTON ══ -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <!-- ══════════════════════════════════════════════════════════════
         LAYOUT PRINCIPAL — panel lateral izquierdo + área de tabla
    ══════════════════════════════════════════════════════════════ -->
    <Grid Background="Transparent">
        <Grid Margin="15,10,15,10">
            <Grid.ColumnDefinitions>
                <!-- Panel lateral: detalle de credencial seleccionada -->
                <ColumnDefinition Width="230"/>
                <ColumnDefinition Width="15"/>
                <!-- Área principal -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ══════════════════════════════════════════════════════
                 COLUMNA 0 — Panel de detalle / formulario
            ══════════════════════════════════════════════════════ -->
            <Border Grid.Column="0" Background="#090924" CornerRadius="12"
                    BorderBrush="#151538" BorderThickness="1" Padding="15">

                <!-- Modo detalle (por defecto) y modo formulario comparten el mismo espacio -->
                <Grid>
                    <!-- ── VISTA DETALLE ── -->
                    <ScrollViewer x:Name="PanelDetalle" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Ícono del servicio -->
                            <Border Width="60" Height="60" CornerRadius="30"
                                    Background="Bisque" HorizontalAlignment="Center"
                                    BorderBrush="#E89A24" BorderThickness="2" Margin="0,0,0,12">
                                <TextBlock x:Name="TxtIconoServicio" Text="🔑"
                                           FontSize="26" HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>

                            <TextBlock x:Name="TxtPanelServicio"
                                       Text="Selecciona una credencial"
                                       FontSize="14" FontWeight="Bold"
                                       Foreground="White" TextAlignment="Center"
                                       TextWrapping="Wrap" HorizontalAlignment="Center"
                                       Margin="0,0,0,4"/>

                            <TextBlock x:Name="TxtPanelCategoria"
                                       Text="—"
                                       FontSize="11" Foreground="#A0A0B8"
                                       TextAlignment="Center" HorizontalAlignment="Center"
                                       Margin="0,0,0,10"/>

                            <Border Background="#1b1b4a" CornerRadius="10"
                                    Padding="10,4" HorizontalAlignment="Center" Margin="0,0,0,14">
                                <TextBlock x:Name="TxtPanelVencimiento"
                                           Text="—" FontSize="11" FontWeight="Bold"
                                           Foreground="#E89A24"/>
                            </Border>

                            <Separator Background="#1F1F45" Margin="0,0,0,14"/>

                            <!-- Campos de detalle -->
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="URL / Servicio" FontSize="10"
                                           Foreground="#3F3F6B" FontWeight="SemiBold"/>
                                <TextBlock x:Name="TxtPanelUrl" Text="—"
                                           FontSize="12" Foreground="#A0A0B8"
                                           TextWrapping="Wrap" Margin="0,2,0,0"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="Usuario / Correo" FontSize="10"
                                           Foreground="#3F3F6B" FontWeight="SemiBold"/>
                                <TextBlock x:Name="TxtPanelUsuario" Text="—"
                                           FontSize="13" Foreground="White"
                                           TextWrapping="Wrap" Margin="0,2,0,0"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="Contraseña" FontSize="10"
                                           Foreground="#3F3F6B" FontWeight="SemiBold"/>
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="30"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="TxtPanelPassword" Text="••••••••"
                                               FontSize="14" Foreground="White"
                                               VerticalAlignment="Center"/>
                                    <Button x:Name="BtnMostrarPassword" Grid.Column="1"
                                            Width="24" Height="24"
                                            Background="Transparent" BorderThickness="0"
                                            Cursor="Hand" ToolTip="Mostrar / Ocultar"
                                            Click="BtnMostrarPassword_Click">
                                        <Path x:Name="EyeIconPanel"
                                              Data="M12,4.5C7,4.5 2.73,7.61 1,12C2.73,16.39 7,19.5 12,19.5C17,19.5 21.27,16.39 23,12C21.27,7.61 17,4.5 12,4.5M12,17A5,5 0 0,1 7,12A5,5 0 0,1 12,7A5,5 0 0,1 17,12A5,5 0 0,1 12,17M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9Z"
                                              Fill="#A0A0B8" Stretch="Uniform" Width="14"/>
                                    </Button>
                                </Grid>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="Notas" FontSize="10"
                                           Foreground="#3F3F6B" FontWeight="SemiBold"/>
                                <TextBlock x:Name="TxtPanelNotas" Text="—"
                                           FontSize="12" Foreground="#A0A0B8"
                                           TextWrapping="Wrap" Margin="0,2,0,0"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,0">
                                <TextBlock Text="Última actualización" FontSize="10"
                                           Foreground="#3F3F6B" FontWeight="SemiBold"/>
                                <TextBlock x:Name="TxtPanelActualizacion" Text="—"
                                           FontSize="12" Foreground="White" Margin="0,2,0,0"/>
                            </StackPanel>

                            <!-- Botones de acción -->
                            <StackPanel Margin="0,16,0,0">
                                <Button x:Name="BtnEditar"
                                        Content="Editar Credencial"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Background="#151538" Foreground="#E89A24"
                                        Margin="0,0,0,8" IsEnabled="False"
                                        Click="BtnEditar_Click"/>
                                <Button x:Name="BtnEliminar"
                                        Content="Eliminar"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Background="#2D1A22" Foreground="#E53E3E"
                                        IsEnabled="False"
                                        Click="BtnEliminar_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- ── VISTA FORMULARIO (oculta por defecto) ── -->
                    <ScrollViewer x:Name="PanelFormulario"
                                  VerticalScrollBarVisibility="Auto"
                                  Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock x:Name="TxtFormTitulo"
                                       Text="Nueva Credencial"
                                       FontSize="14" FontWeight="Bold"
                                       Foreground="White" Margin="0,0,0,14"/>

                            <!-- Servicio -->
                            <TextBlock Text="Nombre del Servicio *" FontSize="11"
                                       Foreground="#A0A0B8" Margin="0,0,0,5"/>
                            <TextBox x:Name="TxtFServicio" Style="{StaticResource ModernInputStyle}"
                                     Margin="0,0,0,10"/>

                            <!-- URL -->
                            <TextBlock Text="URL / Sitio Web" FontSize="11"
                                       Foreground="#A0A0B8" Margin="0,0,0,5"/>
                            <TextBox x:Name="TxtFUrl" Style="{StaticResource ModernInputStyle}"
                                     Margin="0,0,0,10"/>

                            <!-- Usuario -->
                            <TextBlock Text="Usuario / Correo *" FontSize="11"
                                       Foreground="#A0A0B8" Margin="0,0,0,5"/>
                            <TextBox x:Name="TxtFUsuario" Style="{StaticResource ModernInputStyle}"
                                     Margin="0,0,0,10"/>

                            <!-- Contraseña -->
                            <TextBlock Text="Contraseña *" FontSize="11"
                                       Foreground="#A0A0B8" Margin="0,0,0,5"/>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="38"/>
                                </Grid.ColumnDefinitions>
                                <PasswordBox x:Name="PbFPassword" Height="36"
                                             Background="#151538" Foreground="White"
                                             FontSize="13">
                                    <PasswordBox.Resources>
                                        <Style TargetType="PasswordBox">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="PasswordBox">
                                                        <Border x:Name="Brd" Background="{TemplateBinding Background}"
                                                                BorderBrush="#3F3F6B" BorderThickness="1" CornerRadius="6,0,0,6">
                                                            <ScrollViewer x:Name="PART_ContentHost" Margin="10,0,10,0"
                                                                          VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsFocused" Value="True">
                                                                <Setter TargetName="Brd" Property="BorderBrush" Value="#E89A24"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </PasswordBox.Resources>
                                </PasswordBox>
                                <Button Grid.Column="1" x:Name="BtnGenerar"
                                        Height="36" Background="#E89A24"
                                        BorderThickness="0" Cursor="Hand"
                                        ToolTip="Generar contraseña segura"
                                        Click="BtnGenerar_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="0,6,6,0">
                                                <TextBlock Text="⟳" FontSize="16" Foreground="#060621"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>

                            <!-- Categoría -->
                            <TextBlock Text="Categoría" FontSize="11"
                                       Foreground="#A0A0B8" Margin="0,0,0,5"/>
                            <ComboBox x:Name="CbFCategoria"
                                      Style="{StaticResource ModernComboStyle}"
                                      Margin="0,0,0,10">
                                <ComboBoxItem Content="Correo Electrónico"/>
                                <ComboBoxItem Content="Redes Sociales"/>
                                <ComboBoxItem Content="Sistema Interno"/>
                                <ComboBoxItem Content="Banco / Finanzas"/>
                                <ComboBoxItem Content="Desarrollo / DevOps"/>
                                <ComboBoxItem Content="VPN / Acceso Remoto"/>
                                <ComboBoxItem Content="Otro"/>
                            </ComboBox>

                            <!-- Fecha de vencimiento -->
                            <TextBlock Text="Vencimiento de Clave" FontSize="11"
                                       Foreground="#A0A0B8" Margin="0,0,0,5"/>
                            <DatePicker x:Name="DpFVencimiento"
                                        Height="36" Margin="0,0,0,10"/>

                            <!-- Notas seguras -->
                            <TextBlock Text="Notas Seguras" FontSize="11"
                                       Foreground="#A0A0B8" Margin="0,0,0,5"/>
                            <TextBox x:Name="TxtFNotas"
                                     Style="{StaticResource ModernInputStyle}"
                                     Height="60" AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalContentAlignment="Top"
                                     Padding="10,8"
                                     Margin="0,0,0,14"/>

                            <!-- Botones formulario -->
                            <Button x:Name="BtnGuardar"
                                    Content="Guardar Credencial"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Background="#E89A24" Foreground="#060621"
                                    Margin="0,0,0,8"
                                    Click="BtnGuardar_Click"/>
                            <Button x:Name="BtnCancelarForm"
                                    Content="Cancelar"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Background="#151538" Foreground="#A0A0B8"
                                    Click="BtnCancelarForm_Click"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════════════════════
                 COLUMNA 2 — Tabla + controles
            ══════════════════════════════════════════════════════ -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="55"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Margin="0,0,0,15">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Gestor de Contraseñas"
                                   FontSize="18" FontWeight="Bold" Foreground="White"/>
                        <TextBlock x:Name="TxtSubtitulo"
                                   Text="Cifrado AES-256"
                                   FontSize="12" Foreground="#A0A0B8" Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <!-- Búsqueda -->
                        <Border Width="250" Height="36" Background="#151538"
                                BorderBrush="#3F3F6B" BorderThickness="1"
                                CornerRadius="6" Margin="0,0,12,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="35"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="🔍" Foreground="#A0A0B8"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center" FontSize="12"/>
                                <TextBox x:Name="TxtBuscar"
                                         Grid.Column="1"
                                         Background="Transparent" BorderThickness="0"
                                         Foreground="White" VerticalContentAlignment="Center"
                                         FontSize="13" CaretBrush="#E89A24"
                                         TextChanged="TxtBuscar_TextChanged"/>
                            </Grid>
                        </Border>
                        <!-- Nueva credencial -->
                        <Button x:Name="BtnNueva"
                                Content="+ Nueva Credencial"
                                Width="150" Height="36"
                                Background="#E89A24" Foreground="#060621"
                                FontWeight="Bold" BorderThickness="0"
                                Cursor="Hand" Click="BtnNueva_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Tabs de categoría -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,5,0,15">
                    <Button x:Name="BtnTabTodas" Content="Todas"
                            Style="{StaticResource TabFilterButtonStyle}"
                            IsEnabled="False" Tag="0" Click="FilterTab_Click"/>
                    <Button x:Name="BtnTabCorreo" Content="Correo"
                            Style="{StaticResource TabFilterButtonStyle}"
                            Tag="0" Click="FilterTab_Click"/>
                    <Button x:Name="BtnTabSistema" Content="Sistema Interno"
                            Style="{StaticResource TabFilterButtonStyle}"
                            Tag="0" Click="FilterTab_Click"/>
                    <Button x:Name="BtnTabVencidas" Content="⚠ Próx. a Vencer"
                            Style="{StaticResource TabFilterButtonStyle}"
                            Tag="0" Click="FilterTab_Click"/>
                </StackPanel>

                <!-- DataGrid -->
                <Border Grid.Row="2" Background="#090924" CornerRadius="8"
                        BorderBrush="#151538" BorderThickness="1" Padding="10">
                    <DataGrid x:Name="DgCredenciales"
                              Style="{StaticResource ModernDataGridStyle}"
                              SelectionChanged="DgCredenciales_SelectionChanged">
                        <DataGrid.Columns>

                            <!-- Servicio -->
                            <DataGridTextColumn Header="Servicio"
                                               Binding="{Binding NombreServicio}"
                                               Width="1.4*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#E89A24"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Usuario -->
                            <DataGridTextColumn Header="Usuario / Correo"
                                               Binding="{Binding Usuario}"
                                               Width="1.6*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Contraseña (enmascarada) -->
                            <DataGridTextColumn Header="Contraseña"
                                               Binding="{Binding ContrasenaMask}"
                                               Width="1.2*"
                                               ElementStyle="{StaticResource CenterCellStyle}"/>

                            <!-- Categoría -->
                            <DataGridTextColumn Header="Categoría"
                                               Binding="{Binding Categoria}"
                                               Width="1.2*"
                                               ElementStyle="{StaticResource CenterCellStyle}"/>

                            <!-- Vencimiento -->
                            <DataGridTextColumn Header="Vence"
                                               Binding="{Binding VencimientoFormateado}"
                                               Width="1*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="FontWeight" Value="Medium"/>
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="Vencida">
                                                <Setter Property="Foreground" Value="#E53E3E"/>
                                            </Trigger>
                                            <Trigger Property="Text" Value="Sin vencimiento">
                                                <Setter Property="Foreground" Value="#A0A0B8"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Última actualización -->
                            <DataGridTextColumn Header="Actualizado"
                                               Binding="{Binding UltimaActualizacion, StringFormat='{}{0:dd/MM/yyyy}'}"
                                               Width="1*"
                                               ElementStyle="{StaticResource CenterCellStyle}"/>

                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <!-- Paginador -->
                <Grid Grid.Row="3" Margin="0,10,0,0">
                    <TextBlock x:Name="TxtInfoPagina"
                               Text="Página 1 de 1"
                               Foreground="#A0A0B8" FontSize="13"
                               HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button x:Name="BtnPaginaAnterior"
                                Style="{StaticResource PagerButtonStyle}"
                                Click="BtnPaginaAnterior_Click">
                            <TextBlock Text="‹" FontSize="18" FontWeight="Bold" Margin="0,0,0,2"/>
                        </Button>
                        <StackPanel x:Name="PnlNumerosPagina" Orientation="Horizontal"/>
                        <Button x:Name="BtnPaginaSiguiente"
                                Style="{StaticResource PagerButtonStyle}"
                                Click="BtnPaginaSiguiente_Click">
                            <TextBlock Text="›" FontSize="18" FontWeight="Bold" Margin="0,0,0,2"/>
                        </Button>
                    </StackPanel>
                    <TextBlock x:Name="TxtContadorRegistros"
                               Text="Mostrando 0 credenciales"
                               Foreground="#A0A0B8" FontSize="12"
                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
