<UserControl x:Class="Presentación.UserControls.Assign_Inventory"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1050"
             Background="Transparent" x:Name="RootGrid">

    <UserControl.Resources>
        <Style x:Key="FormLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#A0C4E0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="InputStyle" TargetType="Control">
            <Setter Property="Background" Value="#0d3a5c"/>
            <Setter Property="BorderBrush" Value="#1a4a7a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Border x:Name="GridBorder" Grid.Column="0" Background="#09274c" CornerRadius="12" Padding="20" 
                BorderBrush="#0d3a5c" BorderThickness="1">

            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.15" BlurRadius="10" ShadowDepth="2"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock x:Name="TxtTitulo" Text="Inventario Asignado" FontSize="22" FontWeight="Bold" Foreground="White"/>
                        <TextBlock x:Name="TxtSubtitulo" Text="Gestiona los activos a cargo de cada colaborador" FontSize="13" Foreground="#A0C4E0" Margin="0,2,0,0"/>
                    </StackPanel>

                    <Border x:Name="BusquedaBorder" Grid.Column="1" HorizontalAlignment="Right" Width="300" Background="#0d3a5c" 
                            BorderBrush="#1a4a7a" BorderThickness="1" CornerRadius="8" Padding="10,0" Margin="0,0,15,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Path Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z" 
                                  Fill="#A0C4E0" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center"/>

                            <TextBox x:Name="TxtBuscar" Grid.Column="1" Margin="8,0,0,0" 
                                     Background="Transparent" BorderThickness="0" VerticalAlignment="Center" 
                                     Foreground="White" FontSize="13" CaretBrush="White"/>
                        </Grid>
                    </Border>

                    <Button x:Name="BtnNuevaAsignacion" Grid.Column="2" Content="+ Nueva Asignación" 
                            Background="#3B82F6" Foreground="White" BorderThickness="0" 
                            Padding="15,8" FontWeight="SemiBold" Cursor="Hand" Click="BtnNuevaAsignacion_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <DataGrid x:Name="DgAsignaciones" Grid.Row="1" AutoGenerateColumns="False" 
                          Background="Transparent" BorderThickness="0" RowBackground="Transparent" 
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#0d3a5c"
                          HeadersVisibility="Column" SelectionMode="Single" IsReadOnly="True" Foreground="White">

                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#A0C4E0"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="10,12"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#0e3560"/>
                        </Style>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderBrush" Value="#0d3a5c"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#0e3560"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#1a4a7a"/>
                                    <Setter Property="Foreground" Value="#E89A24"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="COLABORADOR" Binding="{Binding NombreColaborador}" Width="*"/>
                        <DataGridTextColumn Header="ACTIVO / EQUIPO" Binding="{Binding NombreActivo}" Width="*"/>
                        <DataGridTextColumn Header="FECHA ASIGNACIÓN" Binding="{Binding FechaAsignacion, StringFormat=dd/MM/yyyy}" Width="150"/>
                        <DataGridTextColumn Header="ESTADO" Binding="{Binding Estado}" Width="120"/>

                        <DataGridTemplateColumn Header="ACCIONES" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Editar" Foreground="#3B82F6" Background="Transparent" 
                                            BorderThickness="0" Cursor="Hand" Click="BtnEditarAsignacion_Click"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Grid Grid.Row="2" Margin="0,15,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock x:Name="TxtInfoPagina" Text="Página 1 de 5" VerticalAlignment="Center" Foreground="#A0C4E0" Margin="0,0,15,0"/>

                        <Button x:Name="BtnPaginaAnterior" Content="Anterior" Background="Transparent" BorderBrush="#0d3a5c" BorderThickness="1" 
                                Foreground="#A0C4E0" Padding="12,6" Margin="0,0,8,0" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" CornerRadius="4">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button x:Name="BtnPaginaSiguiente" Content="Siguiente" Background="Transparent" BorderBrush="#0d3a5c" BorderThickness="1" 
                                Foreground="#A0C4E0" Padding="12,6" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" CornerRadius="4">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Border x:Name="PanelEdicion" Grid.Column="1" Width="320" Background="#09274c" CornerRadius="12" 
                Margin="20,0,0,0" Padding="20" BorderBrush="#0d3a5c" BorderThickness="1" Visibility="Collapsed">

            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.15" BlurRadius="10" ShadowDepth="2"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="TxtTituloPanel" Grid.Row="0" Text="Nueva Asignación" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,20"/>

                <StackPanel Grid.Row="1">
                    <TextBlock Text="Colaborador" Style="{StaticResource FormLabelStyle}"/>
                    <ComboBox x:Name="CmbColaborador" Style="{StaticResource InputStyle}" Margin="0,0,0,15"/>

                    <TextBlock Text="Activo / Dispositivo" Style="{StaticResource FormLabelStyle}"/>
                    <ComboBox x:Name="CmbActivo" Style="{StaticResource InputStyle}" Margin="0,0,0,15"/>

                    <TextBlock Text="Fecha de Asignación" Style="{StaticResource FormLabelStyle}"/>
                    <DatePicker x:Name="DpFechaAsignacion" Margin="0,0,0,15"/>

                    <TextBlock Text="Observaciones" Style="{StaticResource FormLabelStyle}"/>
                    <TextBox x:Name="TxtObservaciones" Style="{StaticResource InputStyle}" Height="80" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,15" CaretBrush="White"/>
                </StackPanel>

                <Grid Grid.Row="2" Margin="0,20,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="BtnCancelar" Grid.Column="0" Content="Cancelar" 
                            Background="#0d3a5c" Foreground="#A0C4E0" BorderThickness="0" 
                            Padding="0,10" FontWeight="SemiBold" Cursor="Hand" Click="BtnCancelar_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button x:Name="BtnGuardar" Grid.Column="2" Content="Guardar" 
                            Background="#3B82F6" Foreground="White" BorderThickness="0" 
                            Padding="0,10" FontWeight="SemiBold" Cursor="Hand" Click="BtnGuardar_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>