<UserControl x:Class="Presentación.PermisosPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1200"
             Visibility="Collapsed">

    <UserControl.Resources>

        <Style x:Key="TabModuloStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A0C4E0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="GroupName" Value="TabModulo"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Brd" Background="{TemplateBinding Background}"
                                BorderBrush="Transparent" BorderThickness="0,0,0,2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Brd" Property="BorderBrush" Value="#2F80ED"/>
                                <Setter TargetName="Brd" Property="Background" Value="#071d34"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter TargetName="Brd" Property="Background" Value="#071d34"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RolButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="#0d3a5c"/>
            <Setter Property="Foreground" Value="#A0C4E0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="GroupName" Value="GrupoRol"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Brd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Brd" Property="Background" Value="#2F80ED"/>
                                <Setter Property="Foreground" Value="#08213a"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Brd" Property="Background" Value="#1a4a7a"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollBarLineButton" TargetType="RepeatButton">
            <Setter Property="Visibility" Value="Collapsed"/>
        </Style>
        <Style x:Key="ScrollBarPageButton" TargetType="RepeatButton">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ScrollBarThumb" TargetType="Thumb">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="Border" CornerRadius="4" Background="#1a4a7a" Margin="2"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#2F80ED"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="8"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Background="Transparent">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <RepeatButton Grid.Row="0" Style="{StaticResource ScrollBarLineButton}" Command="ScrollBar.LineUpCommand"/>
                                    <Track x:Name="PART_Track" Grid.Row="1" IsDirectionReversed="True">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource ScrollBarPageButton}" Command="ScrollBar.PageUpCommand"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource ScrollBarThumb}"/>
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource ScrollBarPageButton}" Command="ScrollBar.PageDownCommand"/>
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                    <RepeatButton Grid.Row="2" Style="{StaticResource ScrollBarLineButton}" Command="ScrollBar.LineDownCommand"/>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

    </UserControl.Resources>

    <!-- Fondo semitransparente de overlay -->
    <Grid>
        <Rectangle Fill="#B0000000" MouseLeftButtonDown="Overlay_Click"/>

        <!-- Panel central -->
        <Border Background="#08213a"
                BorderBrush="#1a4a7a"
                BorderThickness="1"
                CornerRadius="14"
                MaxWidth="980"
                MaxHeight="680"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Margin="40">

            <Grid>
                <Grid.RowDefinitions>
                    <!-- Cabecera -->
                    <RowDefinition Height="64"/>
                    <!-- Tabs de módulos -->
                    <RowDefinition Height="40"/>
                    <!-- Cuerpo -->
                    <RowDefinition Height="*"/>
                    <!-- Pie -->
                    <RowDefinition Height="52"/>
                </Grid.RowDefinitions>

                <!-- ══ CABECERA ══ -->
                <Border Grid.Row="0" Background="#09274c" CornerRadius="14,14,0,0" Padding="20,0">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="40" Height="40" CornerRadius="20" Background="#1a4a7a">
                                <Path Data="M18,8H17V6C17,3.24 14.76,1 12,1C9.24,1 7,3.24 7,6V8H6C4.9,8 4,8.9 4,10V20C4,21.1 4.9,22 6,22H18C19.1,22 20,21.1 20,20V10C20,8.9 19.1,8 18,8M12,17C10.9,17 10,16.1 10,15C10,13.9 10.9,13 12,13C13.1,13 14,13.9 14,15C14,16.1 13.1,17 12,17M15.1,8H8.9V6C8.9,4.28 10.28,2.9 12,2.9C13.72,2.9 15.1,4.28 15.1,6V8Z"
                                      Fill="#2F80ED" Width="20" Height="20" Stretch="Uniform"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Control de Permisos SGSI"
                                           FontSize="15" FontWeight="SemiBold" Foreground="White"/>
                                <TextBlock Text="Gestión granular por módulo, función y rol"
                                           FontSize="11" Foreground="#A0C4E0" Margin="0,1,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Selector de rol + acciones rápidas -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                    HorizontalAlignment="Right">
                            <TextBlock Text="Rol:" FontSize="11" Foreground="#5a8ab0"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <RadioButton x:Name="RbOperador" Content="Operador"
                                         Style="{StaticResource RolButtonStyle}"
                                         IsChecked="True" Margin="0,0,4,0"
                                         Checked="RolChanged"/>
                            <RadioButton x:Name="RbEmpleado" Content="Empleado"
                                         Style="{StaticResource RolButtonStyle}"
                                         Margin="0,0,16,0"
                                         Checked="RolChanged"/>
                            <Button Content="✓ Permitir todo"
                                    Style="{StaticResource AccionButtonStyle}"
                                    Background="#2F80ED" Foreground="#08213a"
                                    Margin="0,0,6,0"
                                    Click="BtnPermitirTodo_Click"/>
                            <Button Content="✗ Denegar todo"
                                    Style="{StaticResource AccionButtonStyle}"
                                    Background="#1a2a3a" Foreground="#e7133f"
                                    Margin="0,0,16,0"
                                    Click="BtnDenegarTodo_Click"/>
                            <Button Width="28" Height="28"
                                    Style="{StaticResource AccionButtonStyle}"
                                    Background="#1a2a3a" Foreground="#A0C4E0"
                                    ToolTip="Cerrar panel de permisos"
                                    Click="BtnCerrar_Click">
                                <Path Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z"
                                      Fill="#A0C4E0" Width="12" Height="12" Stretch="Uniform"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ══ TABS DE MÓDULOS ══ -->
                <Border Grid.Row="1" Background="#071d34" BorderBrush="#0d3a5c"
                        BorderThickness="0,1,0,1">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="TabActivos" Content="Activos"
                                     Style="{StaticResource TabModuloStyle}"
                                     IsChecked="True" Checked="TabModulo_Checked"/>
                        <RadioButton x:Name="TabColaboradores" Content="Colaboradores"
                                     Style="{StaticResource TabModuloStyle}"
                                     Checked="TabModulo_Checked"/>
                        <RadioButton x:Name="TabAsignaciones" Content="Asignaciones"
                                     Style="{StaticResource TabModuloStyle}"
                                     Checked="TabModulo_Checked"/>
                        <RadioButton x:Name="TabContrasenas" Content="Contraseñas"
                                     Style="{StaticResource TabModuloStyle}"
                                     Checked="TabModulo_Checked"/>
                        <RadioButton x:Name="TabAuditoria" Content="Auditoría"
                                     Style="{StaticResource TabModuloStyle}"
                                     Checked="TabModulo_Checked"/>
                        <RadioButton x:Name="TabCategorias" Content="Categorías Activos"
                                     Style="{StaticResource TabModuloStyle}"
                                     Checked="TabModulo_Checked"/>
                        <RadioButton x:Name="TabDashboard" Content="Dashboard"
                                     Style="{StaticResource TabModuloStyle}"
                                     Checked="TabModulo_Checked"/>
                    </StackPanel>
                </Border>

                <!-- ══ CUERPO ══ -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <!-- Lista de grupos de permisos -->
                        <ColumnDefinition Width="200"/>
                        <!-- Separador -->
                        <ColumnDefinition Width="1"/>
                        <!-- Permisos detallados del grupo -->
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Panel izquierdo: grupos de permisos del módulo -->
                    <Border Grid.Column="0" Background="#071d34">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="PnlGrupos" Margin="10,10,10,10"/>
                        </ScrollViewer>
                    </Border>

                    <!-- Separador vertical -->
                    <Rectangle Grid.Column="1" Fill="#0d3a5c"/>

                    <!-- Panel derecho: checkboxes de permisos del grupo seleccionado -->
                    <Grid Grid.Column="2" Background="#08213a">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Subencabezado del grupo -->
                        <Border Grid.Row="0" Background="#09274c"
                                Padding="18,10" BorderBrush="#0d3a5c" BorderThickness="0,0,0,1">
                            <Grid>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock x:Name="TxtGrupoNombre"
                                               Text="Selecciona un grupo"
                                               FontSize="13" FontWeight="SemiBold" Foreground="White"/>
                                    <TextBlock x:Name="TxtGrupoDesc"
                                               Text="Activa o desactiva cada función de forma individual"
                                               FontSize="11" Foreground="#A0C4E0" Margin="0,2,0,0"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                            VerticalAlignment="Center">
                                    <Button x:Name="BtnGrupoPermitir"
                                            Content="Todo el grupo"
                                            Style="{StaticResource AccionButtonStyle}"
                                            Background="#0d3a5c" Foreground="#2F80ED"
                                            Margin="0,0,6,0"
                                            Click="BtnGrupoPermitir_Click"/>
                                    <Button x:Name="BtnGrupoDenegar"
                                            Content="Denegar grupo"
                                            Style="{StaticResource AccionButtonStyle}"
                                            Background="#1a0a0a" Foreground="#e7133f"
                                            Click="BtnGrupoDenegar_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Lista de permisos -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="PnlPermisos" Margin="18,12,18,12"/>
                        </ScrollViewer>
                    </Grid>
                </Grid>

                <!-- ══ PIE ══ -->
                <Border Grid.Row="3" Background="#09274c"
                        CornerRadius="0,0,14,14"
                        Padding="20,0"
                        BorderBrush="#0d3a5c" BorderThickness="0,1,0,0">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Background="#071d34" CornerRadius="6" Padding="10,4" Margin="0,0,12,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Permisos activos: "
                                               FontSize="11" Foreground="#5a8ab0"/>
                                    <TextBlock x:Name="TxtContadorActivos"
                                               Text="0" FontSize="11" FontWeight="Bold" Foreground="#2F80ED"/>
                                    <TextBlock Text=" / "
                                               FontSize="11" Foreground="#5a8ab0"/>
                                    <TextBlock x:Name="TxtContadorTotal"
                                               Text="0" FontSize="11" Foreground="#5a8ab0"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#071d34" CornerRadius="6" Padding="10,4">
                                <TextBlock x:Name="TxtEstadoCambios"
                                           Text="Sin cambios pendientes"
                                           FontSize="11" Foreground="#5a8ab0"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button Content="Cancelar"
                                    Style="{StaticResource AccionButtonStyle}"
                                    Background="#151538" Foreground="#A0A0B8"
                                    Margin="0,0,8,0" Height="36" Width="100"
                                    Click="BtnCerrar_Click"/>
                            <Button x:Name="BtnGuardar"
                                    Content="Guardar Configuración"
                                    Style="{StaticResource AccionButtonStyle}"
                                    Background="#2F80ED" Foreground="#08213a"
                                    Height="36" Width="170"
                                    Click="BtnGuardar_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

            </Grid>
        </Border>
    </Grid>
</UserControl>
